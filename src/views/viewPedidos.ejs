function changeItemsPerPage(limit) {
    const urlParams = new URLSearchParams(window.location.search);
    urlParams.set('limit', limit);
    // urlParams.set('page', 1); // Volver a la primera página
    window.location.search = urlParams.toString();
}

function limpiarFiltros() {
    // Limpiar todos los filtros y volver a la primera página
    const url = new URL(window.location.href);
    url.searchParams.delete('fechaInicio');
    url.searchParams.delete('fechaFin');
    url.searchParams.delete('metodoPago');
    url.searchParams.delete('pedidoId');
    url.searchParams.delete('page');
    window.location.href = url.toString();
}
