<div class="content-example">
    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        Lista de Clientes
         <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3">
            <path d="M440-480q-66 0-113-47t-47-113q0-66 47-113t113-47q66 0 113 47t47 113q0 66-47 113t-113 47Zm0-80q33 0 56.5-23.5T520-640q0-33-23.5-56.5T440-720q-33 0-56.5 23.5T360-640q0 33 23.5 56.5T440-560ZM884-20 756-148q-21 12-45 20t-51 8q-75 0-127.5-52.5T480-300q0-75 52.5-127.5T660-480q75 0 127.5 52.5T840-300q0 27-8 51t-20 45L940-76l-56 56ZM660-200q42 0 71-29t29-71q0-42-29-71t-71-29q-42 0-71 29t-29 71q0 42 29 71t71 29Zm-540 40v-111q0-34 17-63t47-44q51-26 115-44t142-18q-12 18-20.5 38.5T407-359q-60 5-107 20.5T221-306q-10 5-15.5 14.5T200-271v31h207q5 22 13.5 42t20.5 38H120Zm320-480Zm-33 400Z"/>
        </svg>
    </h2>

        <div class="mb-4">
        <input type="text" 
               id="searchClientes" 
               placeholder="Buscar por nombre, apellido, teléfono o dirección..."
               class="w-full p-2 border text-black rounded focus:border-blue-500 focus:outline-none">
    </div>
    
    <div id="clientes-container" class="relative overflow-y-auto max-h-[681px] shadow-md rounded-lg border border-gray-200 custom-scroll">
        <!-- Tabla inicial -->
    </div>
</div>

<!-- Modal para editar cliente -->
<div id="modalEditarCliente" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
    <div class="bg-white rounded-lg p-6 w-full max-w-md">
        <h3 class="text-xl text-black font-bold mb-4">✏️ Editar Cliente</h3>
        
        <form id="formEditarCliente">
            <input type="hidden" id="editClienteId">
            
            <div class="mb-4">
                <label class="block mb-2 font-bold text-gray-700">Nombre: *</label>
                <input type="text" id="editNombre" required 
                       class="w-full p-2 border border-black text-black rounded">
            </div>

            <div class="mb-4">
                <label class="block mb-2 font-bold text-gray-700">Apellido: *</label>
                <input type="text" id="editApellido" required 
                       class="w-full p-2 border border-black text-black rounded">
            </div>
            
            <div class="mb-4">
                <label class="block mb-2 font-bold text-gray-700">Teléfono:</label>
                <input type="text" id="editTelefono" 
                       class="w-full p-2 border border-black text-black rounded">
            </div>
            
            <div class="mb-4">
                <label class="block mb-2 font-bold text-gray-700">Dirección:</label>
                <input type="text" id="editDireccion" 
                       class="w-full p-2 border border-black text-black rounded">
            </div>
            
        <div class="flex gap-2">
                <button type="button" onclick="cerrarModalEditar()" 
                        class="flex-1 bg-gray-500 text-white p-2 rounded hover:bg-gray-600">
                    Cancelar
                </button>
                <button type="submit" 
                        class="flex-1 bg-blue-500 text-white p-2 rounded hover:bg-blue-600">
                    Guardar
                </button>
            </div>
        </form>
    </div>
</div>

<script>
// Variable global para almacenar todos los clientes
let todosLosClientes = [];



// Renderizar lista de clientes
function renderizarClientes(clientes) {
    const container = document.getElementById('clientes-container');
    
    if (!clientes || clientes.length === 0) {
        container.innerHTML = '<p class="text-gray-200 text-center p-4">No hay clientes registrados</p>';
        return;
    }
    
    let html = `
        <table class="w-full text-sm text-left">
            <thead class="sticky top-0 text-xs text-gray-700 uppercase bg-gray-100 z-10">
                <tr>
                    <th scope="col" class="px-6 py-3 font-semibold">Nombre</th>
                    <th scope="col" class="px-6 py-3 font-semibold">Apellido</th>
                    <th scope="col" class="px-6 py-3 font-semibold">Teléfono</th>
                    <th scope="col" class="px-6 py-3 font-semibold">Dirección</th>
                    <th scope="col" class="px-6 py-3 font-semibold">Acciones</th>
                </tr>
            </thead>
            <tbody>
    `;

  clientes.forEach(cliente => {
        const nombreEscaped = (cliente.nombre || '').replace(/'/g, "\\'");
        const apellidoEscaped = (cliente.apellido || '').replace(/'/g, "\\'");
        const telefonoEscaped = (cliente.telefono || '').replace(/'/g, "\\'");
        const direccionEscaped = (cliente.direccion || '').replace(/'/g, "\\'");
        
        html += `
            <tr class="border-b hover:bg-gray-600">
                <td class="p-1">${cliente.nombre || '-'}</td>
                <td class="p-1">${cliente.apellido || '-'}</td>
                <td class="p-1">${cliente.telefono || '-'}</td>
                <td class="p-1">${cliente.direccion || '-'}</td>
                <td class="p-1">
                    <button onclick="editarCliente(${cliente.id}, '${nombreEscaped}', '${apellidoEscaped}', '${telefonoEscaped}', '${direccionEscaped}')"
                            class="icons-custom-color hover:text-blue-600 mt-2" >
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
                    </button>
                    <button onclick="eliminarCliente(${cliente.id})"
                          class="icons-custom-color hover:text-red-600 mt-2 ml-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                    </button>
                </td>
            </tr>
        `;
    });
    
    html += '</tbody></table>';
    container.innerHTML = html;
}

// Función de búsqueda universal
function buscarClientes(termino) {
    if (!termino || termino.trim() === '') {
        renderizarClientes(todosLosClientes);
        return;
    }
    
    const terminoLower = termino.toLowerCase();
    
    const clientesFiltrados = todosLosClientes.filter(cliente => {
        const nombre = (cliente.nombre || '').toLowerCase();
        const apellido = (cliente.apellido || '').toLowerCase();
        const telefono = (cliente.telefono || '').toLowerCase();
        const direccion = (cliente.direccion || '').toLowerCase();
        
        return nombre.includes(terminoLower) || 
               apellido.includes(terminoLower) || 
               telefono.includes(terminoLower) || 
               direccion.includes(terminoLower);
    });
    
    renderizarClientes(clientesFiltrados);
}


// Función para actualizar la lista desde el servidor
function actualizarListaClientes() {
    fetch('/api/obtener-clientes')
        .then(response => response.json())
        .then(data => {
            todosLosClientes = data.clientes;
            // Si hay búsqueda activa, mantenerla
            const searchInput = document.getElementById('searchClientes');
            if (searchInput && searchInput.value.trim()) {
                buscarClientes(searchInput.value);
            } else {
                renderizarClientes(todosLosClientes);
            }
        })
        .catch(error => console.error('Error actualizando clientes:', error));
}


// Editar cliente
function editarCliente(id, nombre, apellido, telefono, direccion) {
    document.getElementById('editClienteId').value = id;
    document.getElementById('editNombre').value = nombre;
    document.getElementById('editApellido').value = apellido;
    document.getElementById('editTelefono').value = telefono;
    document.getElementById('editDireccion').value = direccion;
    
    document.getElementById('modalEditarCliente').classList.remove('hidden');
    document.getElementById('modalEditarCliente').classList.add('flex');
}

function cerrarModalEditar() {
    document.getElementById('modalEditarCliente').classList.add('hidden');
    document.getElementById('modalEditarCliente').classList.remove('flex');
}

// Eliminar cliente
function eliminarCliente(id) {
    if (!confirm('¿Estás seguro de eliminar este cliente?')) return;
    
    fetch(`/eliminarCliente/${id}`, {
        method: 'POST'
    })
    .then(response => response.json())
    .then(result => {
        if (result.success) {
            alert('Cliente eliminado correctamente');
            actualizarListaClientes();
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Error al eliminar el cliente');
    });
}

// Formulario de edición
document.getElementById('formEditarCliente').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const id = document.getElementById('editClienteId').value;
    const data = {
        nombre: document.getElementById('editNombre').value.trim(),
        apellido: document.getElementById('editApellido').value.trim(),
        telefono: document.getElementById('editTelefono').value.trim(),
        direccion: document.getElementById('editDireccion').value.trim()
    };

    fetch(`/editarCliente/${id}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(result => {
        if (result.success) {
            alert('Cliente actualizado correctamente');
            cerrarModalEditar();
            actualizarListaClientes();
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Error al actualizar el cliente');
    });
});

// Escuchar evento de actualización desde la ventana izquierda
window.addEventListener('clientesActualizados', actualizarListaClientes);

// Inicializar con los datos del servidor
document.addEventListener('DOMContentLoaded', function() {
    const clientesIniciales = <%- JSON.stringify(clientes) %>;
    todosLosClientes = clientesIniciales;
    renderizarClientes(todosLosClientes);

    const searchInput = document.getElementById('searchClientes');
    searchInput.addEventListener('input', function(e) {
        buscarClientes(e.target.value);
    });
});
</script>