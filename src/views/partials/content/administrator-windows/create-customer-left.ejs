<div class="content-example">
    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        Agregar Nuevo Cliente
         <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3">
            <path d="M720-400v-120H600v-80h120v-120h80v120h120v80H800v120h-80Zm-360-80q-66 0-113-47t-47-113q0-66 47-113t113-47q66 0 113 47t47 113q0 66-47 113t-113 47ZM40-160v-112q0-34 17.5-62.5T104-378q62-31 126-46.5T360-440q66 0 130 15.5T616-378q29 15 46.5 43.5T680-272v112H40Zm80-80h480v-32q0-11-5.5-20T580-306q-54-27-109-40.5T360-360q-56 0-111 13.5T140-306q-9 5-14.5 14t-5.5 20v32Zm240-320q33 0 56.5-23.5T440-640q0-33-23.5-56.5T360-720q-33 0-56.5 23.5T280-640q0 33 23.5 56.5T360-560Zm0-80Zm0 400Z"/>
        </svg>
    </h2>
    
    <form id="formAgregarCliente" class="space-y-4">
        <div>
            <label class="block mb-2 font-bold text-white">Nombre: *</label>
            <input type="text" name="nombre" required 
                   class="w-full p-2 border text-black rounded focus:border-blue-500 focus:outline-none"
                   placeholder="Ingrese el nombre del cliente">
        </div>
        
        <div>
            <label class="block mb-2 font-bold text-white">Apellido: *</label>
            <input type="text" name="apellido" required 
                   class="w-full p-2 border text-black rounded focus:border-blue-500 focus:outline-none"
                   placeholder="Ingrese el apellido del cliente">
        </div>

        <div>
            <label class="block mb-2 font-bold text-white">Teléfono:</label>
            <input type="tel" type="tel" inputmode="tel" autocomplete="tel" pattern="^\+?\d{7,15}$" name="telefono" 
                   class="w-full p-2 border text-black rounded focus:border-blue-500 focus:outline-none"
                   placeholder="Opcional">
        </div>
        
        <div>
            <label class="block mb-2 font-bold text-white">Dirección:</label>
            <input type="text" name="direccion" 
                   class="w-full p-2 border text-black rounded focus:border-blue-500 focus:outline-none"
                   placeholder="Opcional">
        </div>
        
        <button type="submit" 
                class="w-full bg-blue-500 text-white p-3 rounded hover:bg-blue-600 font-bold">
            💾 Guardar Cliente
        </button>
    </form>
</div>

<script>
// Manejar envío del formulario
document.getElementById('formAgregarCliente').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const data = {
        nombre: formData.get('nombre').trim(),
        apellido: formData.get('apellido').trim(),
        telefono: formData.get('telefono').trim(),
        direccion: formData.get('direccion').trim()
    };

    // Validación básica
    if (!data.nombre) {
        alert('El nombre es obligatorio');
        return;
    }
    
    if (!data.apellido) {
        alert('El apellido es obligatorio');
        return;
    }

    fetch('/insertCliente', {
        method: 'POST',
        headers: { 
            'Content-Type': 'application/json',
            'Accept': 'application/json'  // Agregar este header
        },
        body: JSON.stringify(data)
    })
    .then(response => {
        // Primero parseamos el JSON
        return response.json().then(data => {
            // Retornamos tanto la respuesta como los datos
            return { status: response.status, ok: response.ok, data: data };
        });
    })
     .then(({ status, ok, data }) => {
        if (!ok) {
            // Si hay error, mostramos el mensaje del servidor
            alert(data.error || 'Error desconocido');
            return;
        }
        
        // Si todo fue bien
        if (data.success) {
            alert('Cliente guardado correctamente');
            document.getElementById('formAgregarCliente').reset();
            actualizarListaClientes();
        }
    })
    .catch(error => {
        console.error('Error completo:', error);
        alert('Error al guardar el cliente: ' + error.message);
    });
});

// Función para actualizar la lista (se llama desde la ventana derecha)
function actualizarListaClientes() {
    window.dispatchEvent(new CustomEvent('clientesActualizados'));
}
</script>