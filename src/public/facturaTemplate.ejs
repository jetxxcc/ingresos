<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Factura: No.0<%= pedido.id %>-<%= pedido.nombre_cliente %>-<%= pedido.fecha_pedido %></title>
<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
    padding: 0;
        margin-left: 15px;
    margin-right: 15px;
    padding-top: 160px; /* 🔥 espacio para que no tape la imagen del header */
    padding-bottom: 180px; /* 🔥 espacio para que el contenido no se esconda detrás del footer */
    }

    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px;
    }

    /* Contenedor izquierdo (texto) */
    .info {
        flex: 1;
    }

    .info h2 {
        margin: 0 0 10px 0;
        font-size: 18px;
        font-weight: bold;
    }

    .info-content {
    display: flex;
    flex-direction: column; /* Apila los párrafos verticalmente */
    gap: 5px; /* Espacio uniforme entre los párrafos */
    }

    .info-content p {
        margin: 0; /* Elimina el margin de los párrafos, ya que el gap lo manejará */
        font-size: 14px;
        line-height: 1.4;
    }

    /* Línea divisoria */
    .divider {
      overflow: hidden; 
      display: inline-block; 
      margin: 0.00px 25.00px; 
      background-color: #000000;
      border: 1.33px solid #000000; 
      transform: rotate(0.00rad) translateZ(0px);
       -webkit-transform: rotate(0.00rad) translateZ(0px); 
       width: 2.00px; 
       height: 115.00px;

           -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
    }

    /* Contenedor derecho (logo) */
    .logo {
        text-align: center;
    }

    .logo img {
        width: 120px;
        border-radius: 50%;
    }

        table {
        width: 80%;
        margin: 20px auto;
        border-collapse: collapse; /* elimina espacios entre bordes */
    }

    .container-tabla {
    background-color: #DDB31D;   /* Fondo amarillo */
    padding: 15px;               /* Espaciado interno */
    border-radius: 8px;          /* Opcional: esquinas redondeadas */
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;   /* 🔥 Para que se vea en PDF */
}

    td {
        border-bottom: 1px solid black;
        padding: 8px;
    }

    th {
        background-color: #f2f2f2; /* color suave para cabecera */
        border: 1px solid black; /* borde de 1px */
        padding: 8px;
        
        
    }

    .rowTitleOne{
        padding-left: 120px;
        text-align: justify;
    }

    .rowTitleTwo{
        text-align: center;
    }

    .total-box {
        margin-top: 10px;       /* espacio entre tabla y total */
        margin-right: 0;  /* sin margen extra */
    display: inline-block;
    float: right;           /* 🔥 alinea a la derecha */
    background: black;      /* fondo negro */
    color: white;           /* texto blanco */
    padding: 8px 20px;      /* espacio interno */
    border-radius: 5px;     /* esquinas redondeadas */
    font-weight: bold;
    font-size: 16px;

       /* 🔥 Fuerza colores en PDF */
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
}


/* inicio de imagen fijo*/
    .header-image {
        position: fixed;
        top: 0;       /* 🔥 pegado arriba */
        left: 0;
        padding-bottom: 50px;
        width: 100%;
        height: 190px; /* ajusta la altura del área del header */
        transform: translateY(-30px);
        overflow: hidden;
        z-index: -1;  /* lo manda detrás del contenido */
    }
    
    .header-bg {
        width: 100%;
        height: auto;
        object-fit: cover;
    }

      /* fin de imagen fijo */
    .footer {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 230px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: white;
    overflow: hidden;
}


.footer-bg {
    position: absolute;
    bottom: 0;       /* pegada abajo */
    left: 0;
    width: 100%;
    height: auto;
    transform: translateY(30px); /* 🔥 ajusta hacia ARRIBA o ABAJO */
    z-index: 1;
}


.footer-content {
    position: relative;
    z-index: 2;
    padding-top: 80px;
}
</style>
</head>
<body>

<div class="wave-top"></div>
<div class="header-image">
    <img src="<%= headerLogoBase64 %>" class="header-bg" alt="Encabezado">
</div>
<div class="header">
    <div class="info">
        <br>
         <h2>FACTURA. #0<%= pedido.id %></h2>
         <hr>
            <div class="info-content">
                    <p>Fecha: <%= pedido.fecha_pedido %></p>    
                    <p>Cliente: <%= pedido.nombre_cliente %></p>
                    <p>Método de pago: <%= pedido.metodo_pago %></p>
                    <p>Atención al cliente por: <%= pedido.usuario %></p>
            
            </div>
    </div>

    <div class="divider"></div>

    <div class="logo">
        <img src="<%= mainLogoBase64 %>" alt="Logo">
    </div>
</div>

<hr>

<div class="container-tabla">
        <table>
            <tr>
                <th class="rowTitleOne">Descripción</th>
                <th class="rowTitleTwo">Precio</th>
            </tr>
            <% detalles.forEach(item => { %>
        <tr>
            <td><%= item.producto_nombre %></td>
            <td><%= item.producto_precio %></td>
        </tr>
        <% }); %>
    </table>
    <div class="total-box">
        <span>Total:</span> <strong>RD$<%= pedido.total_pedido %></strong>
    </div>
</div>

<div class="footer">
    <img src="<%= footerWaveBase64 %>" class="footer-bg" alt="fondo">
    <div class="footer-content">
        <p>CONTÁCTANOS</p>
        <p>INSTAGRAM: @SHALOMSTUDIO_BYELIANNY</p>
        <p>CORREO: SHALOMSTUDIOELIANNY@ICLOUD.COM</p>
        <p>WHATSAPP: 829-333-5420</p>
    </div>
</div>


</body>
</html>
